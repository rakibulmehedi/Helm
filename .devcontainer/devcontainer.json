{
  "name": "Helm (Flutter/Dart)",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
  "features": {
    "ghcr.io/devcontainers-community/features/flutter:1": {}
  },
  "postCreateCommand": "flutter pub get",
  "customizations": {
    "vscode": {
      "extensions": [
        "Dart-Code.dart-code",
        "Dart-Code.flutter"
      ],
      "settings": {
        "dart.flutterSdkPath": "/usr/local/flutter"
      }
    }
  },
  "remoteUser": "vscode"
}
